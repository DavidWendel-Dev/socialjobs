# =========================================================================
# .env.docker — perfil de exemplo para docker-compose
# Copie para .env quando for rodar via Docker: `cp .env.docker .env`
# =========================================================================

APP_NAME="SocialJobs"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ===== Banco (contêiner mysql) =====
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=socialjobs
DB_USERNAME=socialjobs
DB_PASSWORD=change-me-strong-password

# ===== Sessão / cache / fila via Redis (contêiner redis) =====
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===== Broadcast / WebSocket (contêiner reverb) =====
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=socialjobs
REVERB_APP_KEY=change-me-app-key
REVERB_APP_SECRET=change-me-app-secret
REVERB_HOST=ws.example.com
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ===== Mail (SMTP externo em produção) =====
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===== Busca (contêiner meilisearch) =====
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=change-me-meili-master-key

# ===== Storage S3 (opcional) =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===== Storage de mídia =====
MEDIA_DISK=public
MEDIA_PUBLIC_URL=

# ===== Cloudflare R2 (opcional, quando MEDIA_DISK=r2) =====
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
R2_ENDPOINT=
R2_PUBLIC_URL=

# ===== OAuth =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"

# ===== IA (OpenAI-compatible) =====
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT=60

AI_STT_BASE_URL="${AI_BASE_URL}"
AI_STT_API_KEY="${AI_API_KEY}"
AI_STT_MODEL=whisper-1

AI_TTS_BASE_URL="${AI_BASE_URL}"
AI_TTS_API_KEY="${AI_API_KEY}"
AI_TTS_MODEL=tts-1
AI_TTS_VOICE=alloy

OPENAI_API_KEY="${AI_API_KEY}"
OPENAI_ORGANIZATION=
OPENAI_BASE_URI="${AI_BASE_URL}"
OPENAI_REQUEST_TIMEOUT=60

VITE_APP_NAME="${APP_NAME}"

# ===== Trusted Proxies (atrás de Cloudflare/Nginx/etc.) =====
TRUSTED_PROXIES=*
