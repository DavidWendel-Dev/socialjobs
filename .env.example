APP_NAME="SocialJobs"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================
# Database
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=socialjobs
DB_USERNAME=root
DB_PASSWORD=

# ============================================================
# Session / Cache / Queue
# ============================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# ============================================================
# Broadcasting (Laravel Reverb — Websockets)
# ============================================================
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=socialjobs
REVERB_APP_KEY=socialjobs_key
REVERB_APP_SECRET=socialjobs_secret
REVERB_HOST="127.0.0.1"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ============================================================
# Redis
# ============================================================
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# Mail
# ============================================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# Search (Laravel Scout / Meilisearch)
# ============================================================
SCOUT_DRIVER=database
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# ============================================================
# AWS S3 (opcional, para storage remoto)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# Storage de mídia (avatars, capas, imagens de posts)
# MEDIA_DISK=public  → armazena localmente em storage/app/public
# MEDIA_DISK=r2      → armazena no Cloudflare R2 e serve via CDN
# ============================================================
MEDIA_DISK=public
MEDIA_PUBLIC_URL=

# Cloudflare R2 (usado apenas quando MEDIA_DISK=r2)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
R2_ENDPOINT=
R2_PUBLIC_URL=

# ============================================================
# OAuth (Socialite)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"

# ============================================================
# AI provider (OpenAI-compatible: OpenAI, Groq, Ollama, etc.)
# ============================================================
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT=60

AI_STT_BASE_URL="${AI_BASE_URL}"
AI_STT_API_KEY="${AI_API_KEY}"
AI_STT_MODEL=whisper-1

AI_TTS_BASE_URL="${AI_BASE_URL}"
AI_TTS_API_KEY="${AI_API_KEY}"
AI_TTS_MODEL=tts-1
AI_TTS_VOICE=alloy

OPENAI_API_KEY="${AI_API_KEY}"
OPENAI_ORGANIZATION=
OPENAI_BASE_URI="${AI_BASE_URL}"
OPENAI_REQUEST_TIMEOUT=60

VITE_APP_NAME="${APP_NAME}"
